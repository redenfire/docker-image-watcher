# Project environment for OpenCode and model routes.
# This file is NOT loaded automatically by Windows, Linux, macOS, or OpenCode.
# Use scripts/start-opencode.ps1 or scripts/start-opencode.sh.
# Keep syntax shell-compatible: NAME=value, no spaces around '='.

# FreeLLMAPI shared gateway.
FREELLMAPI_BASE_URL=http://freellmapi.example.lan:3001/v1
FREELLMAPI_API_KEY=replace-me

# DeepSeek API: default paid/cheap frontier OpenCode route.
DEEPSEEK_API_KEY=replace-me

# OpenAI API backup route only.
# Leave commented unless intentionally spending personal OpenAI API credit.
# OPENAI_API_KEY=replace-me

# Optional: tune OpenCode/logging in local shells if needed.
# OPENCODE_LOG_LEVEL=debug
