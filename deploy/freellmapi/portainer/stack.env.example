# FreeLLMAPI encryption key.
# Must be a 64-character hexadecimal string.
# Generate once, then keep permanently:
#   Linux/macOS: openssl rand -hex 32
#   PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Minimum 0 -Maximum 256) })
FREELLMAPI_ENCRYPTION_KEY=replace-with-64-hex-characters
